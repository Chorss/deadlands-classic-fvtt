{
  "permissions": {
    "allow": [
      "Bash(node:*)",
      "Bash(node --check:*)",
      "Bash(node --test:*)",
      "Bash(npm run test:*)",
      "Bash(npm run fmt:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run verify:*)",
      "Bash(npm ci:*)",
      "Bash(npm install:*)",
      "Bash(npx biome:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git fetch:*)",
      "Bash(git tag:*)",
      "Bash(git branch:*)",
      "Bash(git rev-list:*)",
      "Bash(git stash:*)",
      "Bash(gh pr:*)",
      "Bash(gh run:*)",
      "Bash(awk:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(ln -s:*)",
      "Bash(chmod +x:*)",
      "Bash(pdftotext:*)",
      "WebFetch(domain:foundryvtt.com)",
      "WebFetch(domain:foundryvtt.wiki)",
      "WebSearch"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -rf /)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Bash(git clean -fd:*)",
      "Bash(git clean -fdx:*)"
    ]
  },
  "env": {
    "DEADLANDS_DEV": "1"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git config core.hooksPath .githooks >/dev/null 2>&1 || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post-write.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post-extract-verify.sh"
          }
        ]
      }
    ]
  }
}
