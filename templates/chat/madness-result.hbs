{{!-- Chat card (GM whisper): Mad Scientist Black Joker madness table result. --}}
<div class="dlc-chat-card dlc-madness-result">
  <header class="dlc-chat-header">
    <span class="dlc-actor-name">{{actorName}}</span>
    <span class="dlc-chat-verb">{{localize "DEADLANDS.MadScientist.Chat.MadnessHeader"}}</span>
  </header>

  <div class="dlc-madness-details">
    <p>{{localize "DEADLANDS.MadScientist.Chat.MadnessRoll"}}: <strong>{{roll}}</strong></p>
    <p class="dlc-madness-label">{{localize labelKey}}</p>
    <p class="dlc-madness-note">{{localize noteKey}}</p>
  </div>
</div>
