{{!-- Dialog: perform a ritual to earn Appeasement (Shaman). --}}
<form class="dlc-dialog-form">
  <p class="dlc-dialog-intro">
    {{localize "DEADLANDS.Shaman.Dialog.RitualIntro"}}:
    <strong>{{favorName}}</strong>
    ({{localize "DEADLANDS.Shaman.FavorTable.TN"}}: {{ritualTN}})
  </p>
  <p class="dlc-dialog-sub">{{localize ritualTypeLabel}}</p>

  <div class="dlc-form-row">
    <label for="modifier">{{localize "DEADLANDS.Dialog.Modifier"}}</label>
    <input type="number" id="modifier" name="modifier" value="0" />
  </div>
</form>
