{{!-- Favors tab: ritual aptitude, Appeasement pool, favor list. --}}
<section class="tab dlc-favors {{tab.cssClass}}" data-group="sheet" data-tab="favors">

  {{!-- Ritual aptitude --}}
  <div class="dlc-ritual">
    <h2 class="dlc-section-title">{{localize "DEADLANDS.Shaman.Ritual.Label"}}</h2>
    <div class="dlc-ritual-row">
      <label for="dlc-ritual-level">{{localize "DEADLANDS.Shaman.Ritual.Level"}}</label>
      <input type="number" id="dlc-ritual-level" min="0" name="{{ritual.levelPath}}"
        value="{{ritual.level}}" {{#unless editable}}disabled{{/unless}} />
      <label for="dlc-ritual-mod">{{localize "DEADLANDS.Shaman.Ritual.Modifier"}}</label>
      <input type="number" id="dlc-ritual-mod" name="{{ritual.modifierPath}}"
        value="{{ritual.modifier}}" {{#unless editable}}disabled{{/unless}} />
    </div>
  </div>

  {{!-- Guardian Spirit + Appeasement pool --}}
  <div class="dlc-appeasement">
    <h2 class="dlc-section-title">{{localize "DEADLANDS.Shaman.Appeasement.Label"}}</h2>
    <div class="dlc-appeasement-row">
      <label for="dlc-guardian-spirit">{{localize "DEADLANDS.Shaman.GuardianSpirit.Label"}}</label>
      <input type="number" id="dlc-guardian-spirit" min="0" max="5" name="system.guardianSpirit"
        value="{{guardianSpirit}}" {{#unless editable}}disabled{{/unless}} />
      {{#if guardianSpirit}}
      <span class="dlc-appeasement-pool">
        {{localize "DEADLANDS.Shaman.Appeasement.Stored"}}:
        <strong>{{appeasement.current}} / {{appeasement.max}}</strong>
      </span>
      {{else}}
      <span class="dlc-appeasement-note">{{localize "DEADLANDS.Shaman.Appeasement.NoStorage"}}</span>
      {{/if}}
    </div>
  </div>

  {{!-- Favor list --}}
  <div class="dlc-favor-list">
    <h2 class="dlc-section-title">{{localize "DEADLANDS.Shaman.Section.Favors"}}</h2>
    {{#if favors.length}}
    <table class="dlc-favor-table">
      <thead>
        <tr>
          <th>{{localize "DEADLANDS.Shaman.FavorTable.Name"}}</th>
          <th>{{localize "DEADLANDS.Shaman.FavorTable.Medicine"}}</th>
          <th>{{localize "DEADLANDS.Shaman.FavorTable.RitualType"}}</th>
          <th>{{localize "DEADLANDS.Shaman.FavorTable.Cost"}}</th>
          <th>{{localize "DEADLANDS.Shaman.FavorTable.TN"}}</th>
          <th>{{localize "DEADLANDS.Shaman.FavorTable.Duration"}}</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        {{#each favors as |f|}}
        <tr class="dlc-favor-row" data-favor-id="{{f.id}}">
          <td class="dlc-favor-name">
            <img class="dlc-item-img" src="{{f.img}}" alt="{{f.name}}" />
            {{f.name}}
          </td>
          <td>{{localize f.medicineLabel}}</td>
          <td>{{localize f.ritualTypeLabel}}</td>
          <td>{{f.appeasementCost}}</td>
          <td>{{f.ritualTN}}</td>
          <td>{{f.duration}}</td>
          <td class="dlc-favor-actions">
            {{#if @root.editable}}
            <button type="button" class="dlc-ritual-btn"
              data-action="performRitual" data-favor-id="{{f.id}}">
              {{localize "DEADLANDS.Shaman.Ritual.Button"}}
            </button>
            {{#if @root.guardianSpirit}}
            <button type="button" class="dlc-spend-btn"
              data-action="spendFavor" data-favor-id="{{f.id}}">
              {{localize "DEADLANDS.Shaman.Spend.Button"}}
            </button>
            {{/if}}
            {{/if}}
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
    {{else}}
    <p class="dlc-empty">{{localize "DEADLANDS.Sheet.Empty.Favors"}}</p>
    {{/if}}
  </div>

</section>
