{{!-- Combat: Fate Chips, wound track, and weapons. Full wound widget in Phase 6. --}}
<section class="tab dlc-combat {{tab.cssClass}}" data-group="sheet" data-tab="combat">
  <div class="dlc-chips">
    <h2 class="dlc-section-title">{{localize 'DEADLANDS.Sheet.Section.Chips'}}</h2>
    <ul class="dlc-chip-row">
      {{#each chips as |chip|}}
      <li class="dlc-chip dlc-chip-{{chip.color}}">
        <label class="dlc-chip-label" for="dlc-chip-{{chip.color}}">{{localize chip.label}}</label>
        <input type="number" id="dlc-chip-{{chip.color}}" min="0" name="{{chip.path}}" value="{{chip.value}}"
          {{#unless @root.editable}}disabled{{/unless}} />
      </li>
      {{/each}}
    </ul>
  </div>

  <div class="dlc-wounds">
    {{!-- Wind bar --}}
    <div class="dlc-wind-bar {{wounds.windedClass}}">
      <h2 class="dlc-section-title">{{localize "DEADLANDS.Sheet.Wind"}}</h2>
      <div class="dlc-wind-track">
        <input type="number" class="dlc-wind-value" name="system.wind.value"
          value="{{wounds.wind.value}}" min="0" max="{{wounds.wind.max}}" data-dtype="Number"
          aria-label="{{localize 'DEADLANDS.Sheet.Wind'}}"
          {{#unless @root.editable}}disabled{{/unless}} />
        <span class="dlc-wind-sep">/</span>
        <span class="dlc-wind-max">{{wounds.wind.max}}</span>
        {{#if wounds.windedClass}}<span class="dlc-winded-badge">{{localize "DEADLANDS.Wound.Winded"}}</span>{{/if}}
      </div>
    </div>

    {{!-- 8-slot wound track --}}
    <h2 class="dlc-section-title">{{localize "DEADLANDS.Sheet.Section.Wounds"}}</h2>
    <ul class="dlc-wound-list">
      {{#each wounds.woundLocations as |wound|}}
      <li class="dlc-wound {{#if wound.isMaimed}}dlc-maimed{{/if}}" data-location="{{wound.id}}">
        <span class="dlc-wound-label">{{localize wound.label}}</span>
        <div class="dlc-wound-pips">
          {{#each wound.pips}}<span class="dlc-wound-pip {{#if filled}}dlc-pip-filled{{/if}}"></span>{{/each}}
        </div>
        <input type="number" class="dlc-wound-sev" min="0" max="5" name="{{wound.path}}"
          value="{{wound.severity}}" {{#unless @root.editable}}disabled{{/unless}}
          aria-label="{{localize wound.label}} {{localize 'DEADLANDS.Sheet.Aria.WoundSeverity'}}" />
        {{#if wound.severity}}<span class="dlc-wound-severity">{{localize wound.severityLabel}}</span>{{/if}}
      </li>
      {{/each}}
    </ul>
  </div>

  <div class="dlc-weapons">
    <h2 class="dlc-section-title">{{localize 'DEADLANDS.Sheet.Section.Weapons'}}</h2>
    {{#if items.weapon.length}}
    <ul class="dlc-item-list">
      {{#each items.weapon as |weapon|}}
      <li class="dlc-item" data-item-id="{{weapon.id}}">
        <img class="dlc-item-img" src="{{weapon.img}}" alt="{{weapon.name}}" />
        <span class="dlc-item-name">{{weapon.name}}</span>
      </li>
      {{/each}}
    </ul>
    {{else}}
    <p class="dlc-empty">{{localize 'DEADLANDS.Sheet.Empty.Weapons'}}</p>
    {{/if}}
  </div>
</section>
